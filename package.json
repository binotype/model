{
	"name": "@binotype/model",
	"version": "1.7.1-beta.0",
	"description": "Library with data types for Binotype Sites.",
	"author": "Binotype Contributors",
	"license": "MIT",
	"private": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/binotype/model"
	},
	"bugs": {
		"url": "https://github.com/binotype/model/issues"
	},
	"homepage": "https://github.com/binotype/model",
	"type": "module",
	"module": "./dist/mjs/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/index.d.ts",
				"default": "./dist/mjs/index.js"
			}
		}
	},
	"git": {
		"tagName": "v${version}"
	},
	"github": {
		"release": true
	},
	"scripts": {
		"lint": "biome format .",
		"format": "biome format --write .",
		"prebuild": "rimraf dist/*",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"coverage": "vitest --coverage",
		"prepare": "npm run build",
		"clean": "rimraf dist node_modules coverage",
		"verify": "npm run build && npm run test && npm run lint && npm --omit=dev audit"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^4.1.5",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"@biomejs/biome": "^2.4.13"
	},
	"dependencies": {
		"@stencil/core": "^4.43.4",
		"@typeup/dom": "1.0.11-beta.3",
		"@typeup/parser": "1.2.5-beta.2",
		"isly": "1.8.0",
		"isoly": "3.1.8"
	}
}
