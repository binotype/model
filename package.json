{
	"name": "@binotype/model",
	"version": "0.0.0",
	"description": "Library with data types for Binotype Sites.",
	"author": "Binotype Contributors",
	"license": "MIT",
	"private": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/binotype/model"
	},
	"bugs": {
		"url": "https://github.com/binotype/model/issues"
	},
	"homepage": "https://github.com/binotype/model",
	"type": "module",
	"module": "./dist/mjs/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/index.d.ts",
				"default": "./dist/mjs/index.js"
			}
		}
	},
	"git": {
		"tagName": "v${version}"
	},
	"github": {
		"release": true
	},
	"scripts": {
		"lint": "eslint --max-warnings=0 '**/*.{ts,tsx}'",
		"fix": "eslint '**/*.{ts,tsx}' --fix",
		"prebuild": "rimraf dist/*",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"coverage": "vitest --coverage",
		"prepare": "npm run build",
		"clean": "rimraf dist node_modules coverage",
		"verify": "npm run build && npm run test && npm run lint && npm --omit=dev audit"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "8.57.2",
		"@typescript-eslint/parser": "8.57.2",
		"@vitest/coverage-v8": "^4.1.1",
		"eslint": "^9.39.4",
		"eslint-plugin-prettier": "",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"prettier": "",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"vite": "^6.4.1",
		"vitest": "^4.1.1"
	},
	"dependencies": {
		"isly": "1.8.0",
		"isoly": "3.1.8"
	}
}
